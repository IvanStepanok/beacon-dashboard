# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
# Public build-time config (NEXT_PUBLIC_* only, no secrets) — committed on purpose:
# without it a fresh build bakes the localhost:8080 fallback into the bundle.
!.env.production

# QA screenshots from emulator/browser test sessions — not part of the app
/public-shots/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
